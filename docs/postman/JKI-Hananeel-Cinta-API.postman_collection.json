              "host": [
                "{{base_url}}"
              ],
              "path": [
                "pastor-messages"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                }
              ]
            }
          }
        },
        {
          "name": "Pastor Message Detail",
          "request": {
            "method": "GET",
