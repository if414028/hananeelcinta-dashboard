                "{{pastor_message_slug}}"
              ]
            }
          }
        },
        {
          "name": "Family Altars",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/family-altars?per_page=15&day=sunday",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "family-altars"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                },
                {
                  "key": "day",
                  "value": "sunday"
                }
              ]
            }
          }
        },
        {
          "name": "Family Altar Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/family-altars/{{family_altar_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "family-altars",
                "{{family_altar_id}}"
              ]
            }
          }
        },
        {
          "name": "Submit Prayer Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-App-Platform",
                "value": "android"
              },
              {
                "key": "X-App-Version",
                "value": "1.0.0"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Pengguna Mobile\",\n  \"email\": \"user@example.com\",\n  \"phone_number\": \"+628123456789\",\n  \"prayer_category\": \"other\",\n  \"prayer_content\": \"Mohon dukungan doa untuk keluarga kami.\",\n  \"is_anonymous\": false,\n  \"is_confidential\": true,\n  \"privacy_accepted\": true,\n  \"client_platform\": \"android\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/prayer-requests",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "prayer-requests"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Mobile Auth",
      "auth": {
        "type": "bearer",
        "bearer": [
          {
            "key": "token",
            "value": "{{firebase_id_token}}",
            "type": "string"
          }
        ]
      },
      "item": [
        {
          "name": "Create Firebase Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-App-Platform",
                "value": "android"
              },
              {
                "key": "X-App-Version",
                "value": "1.0.0"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/session",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "session"
              ]
            }
          }
        },
        {
          "name": "Current Mobile Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "X-App-Platform",
                "value": "android"
              },
              {
                "key": "X-App-Version",
                "value": "1.0.0"
              }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "me"
              ]
            }
          }
        }
      ]
    }
  ]
