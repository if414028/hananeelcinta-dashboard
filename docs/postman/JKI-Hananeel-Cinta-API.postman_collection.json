          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/announcements?per_page=15&featured=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "announcements"
              ],
              "query": [
                {
                  "key": "per_page",
                  "value": "15"
                },
                {
                  "key": "featured",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "Announcement Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/announcements/{{announcement_slug}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "announcements",
                "{{announcement_slug}}"
              ]
            }
          }
        },
        {
          "name": "Pastor Messages",
          "request": {
            "method": "GET",
