{
  "info": {
    "_postman_id": "f7cb3d7e-1dfa-48e6-8689-8c09a4c6fd36",
    "name": "JKI Hananeel Cinta API v1",
    "description": "Collection resmi REST API v1. Isi firebase_id_token dengan Firebase ID token aktif untuk folder Mobile Auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api/v1",
      "type": "string"
    },
    {
      "key": "firebase_id_token",
      "value": "",
      "type": "secret"
    },
    {
      "key": "announcement_slug",
      "value": "contoh-pengumuman",
      "type": "string"
    },
    {
      "key": "pastor_message_slug",
      "value": "contoh-pastor-message",
      "type": "string"
    },
    {
      "key": "family_altar_id",
      "value": "1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('Response is JSON', function () {",
          "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
          "});",
          "pm.test('Request ID is present', function () {",
          "  pm.expect(pm.response.headers.get('X-Request-Id')).to.be.ok;",
          "});"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Config",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/config",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "config"
              ]
            }
          }
        },
        {
          "name": "Home",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/home",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "home"
              ]
            }
